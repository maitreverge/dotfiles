export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="jonathan"

plugins=(git)

# Redefine $PATH env
export PATH=$HOME/.local/bin:$HOME/Documents/android-studio/bin:$PATH:$HOME/snap/code/233/.local/share/../bin

source $ZSH/oh-my-zsh.sh

alias master_update="sudo apt update && sudo apt upgrade -y && sudo apt --fix-broken install -y && sudo apt autoremove -y && sudo apt clean"

# COMMANDES CD
alias gotest="~/Documents/test"
alias godev="~/Documents/dev"
alias gocorrection="~/Documents/corrections"
alias godownload="~/Downloads"

# COMMANDES PEDAGO

# ALIAS DE COMPILATEUR

# ALIAS DE COMPILATEUR AVEC VALGRIND FLAG -G

# ALIAS VALGRIND
alias valgrind_full="valgrind --leak-check=full --show-leak-kinds=all"
alias valgrind_mute_child="valgrind --child-silent-after-fork=yes"
alias datarace="valgrind --tool=helgrind"

# ALIAS DE NORMINETTE

# ALIAS GIT
alias gs="git status"
alias gp='git push'
alias gpll='git pull'
alias gl='git log --pretty=format:"%h %s"'

# `git tree` is now a valid alias
git config --global alias.tree "log --oneline --graph --all --decorate"

# UMASK SETTINGS
umask 002

# SCRIPT FULL ADD + FULL COMMIT
function gcam() {
    git add -A && git add . && git commit -m "$1"
}
alias gcam='gcam'

# ALIAS DIVERS
alias lookfor='find . -name'
alias rmF='rm -Rf'
alias open="xdg-open ."
alias zzz="zellij"
alias gozshrc="vim ~/.zshrc"
alias seezshrc="cat ~/.zshrc"
alias p3="python3"
alias f8="flake8"
alias open="xdg-open ."
alias rust="evcxr"
alias cl="clear"
alias lzd="lazydocker"
alias chx="chmod +x"

## COPY ALIASES
# Wayland
alias copy_wl="wl-copy"
# x11
alias copy_x11="xclip -selection clipboard"

# VNC CASTING 42
alias cast42="x11vnc -display :0 -clip 3840x2160+1920+0 -ncache_cr -cursor most -nocursorshape -noxdamage -forever -rfbauth ~/.vnc/passwd"

# PYTHON CHECKER
pcheck() {
  black "$@" && mypy "$@" && flake8 "$@" && pylint "$@"
}

LS_COLORS="ex=1;31:$LS_COLORS"
export LS_COLORS


# Turn on Zellij by default is $ZELLIJ exists in current env
# Also disable it when running in VS Code or Zed
if [[ ! -v $ZELLIJ && ! "$TERM_PROGRAM" = "vscode" ]]; then
    zellij --layout compact
fi

. "$HOME/snap/code/233/.local/share/../bin/env"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
